# Application Secret Key (Must be at least 32 characters)
APP_MASTER_KEY=your_very_long_secret_key_please_change_this_to_something_secure

# UI/API admin login password
APP_ADMIN_PASSWORD=change_this_admin_password

# Allowed browser origin for CORS/session cookies
APP_ALLOWED_ORIGIN=http://localhost:3000

# Runtime basics
NODE_ENV=production
DATA_DIR=/data

# Optional hostname override used by docker-compose extra_hosts
CALDAV_HOSTNAME=nas.local
CALDAV_HOST_IP=192.168.1.10

# Set true only if browser accesses app over HTTPS
APP_SECURE_COOKIES=false

# Optional: enable verbose calendar tracing logs (ics parse -> DB -> PDF input)
# Accepted truthy values: 1, true, yes, on
CALENDAR_TRACE=0

# Optional trace switches (each can be enabled independently)
CAL_TRACE_INGEST=0
CAL_TRACE_SYNC=0
CAL_TRACE_PDF=0
CAL_TRACE_TZ_FALLBACK=0

# Optional trace shaping
# Max trace entries per trace stream invocation
CAL_TRACE_LIMIT=80
# Restrict PDF trace to one day (YYYY-MM-DD), blank = all days
CAL_TRACE_DAY=

# NOTE: Device SSH credentials are now managed per-device in the UI.
# Legacy REMARKABLE_* environment variables are no longer used for sync auth.

# Sync Settings
# Set to 'true' to test without changing anything on device
SYNC_DRY_RUN=false
# Set to 'true' to keep a copy of the old file before overwriting
SYNC_BACKUP_REMOTE=true

# Backup Retention Settings
# How many days to keep old backups (oldest deleted first, newest 3 always protected)
BACKUP_RETENTION_DAYS=7
# Maximum number of backups to keep per device
BACKUP_MAX_COUNT=5
# Maximum total backup storage per device in gigabytes
BACKUP_MAX_TOTAL_SIZE_GB=5
