# Application Secret Key (Must be at least 32 characters)
APP_MASTER_KEY=your_very_long_secret_key_please_change_this_to_something_secure

# Authentication (Basic Auth)
AUTH_USER=admin
AUTH_PASS=password

# SSH Configuration
REMARKABLE_HOST=10.11.99.1
REMARKABLE_USER=root
REMARKABLE_SSH_KEY_PATH=/app/ssh_key
REMARKABLE_PORT=22

# Sync Settings
SYNC_DRY_RUN=false
SYNC_BACKUP_REMOTE=true

# Data Directory (Inside Container)
DATA_DIR=/data
